RewriteEngine On

# Only apply these rules for suprachar.com and www.suprachar.com
RewriteCond %{HTTP_HOST} ^(www\.)?suprachar\.com$ [NC]

# Send the site root to the /suprachar/ folder
RewriteRule ^/?$ /suprachar/ [L,R=302]

# Send all other requests to the matching page inside /suprachar/
RewriteCond %{REQUEST_URI} !^/suprachar/ [NC]
RewriteRule ^(.+)$ /suprachar/$1 [L,R=302]

# Default page inside the target folder
DirectoryIndex index.html
